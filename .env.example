# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-django-insecure

# Database
# For local development, leave this empty to use SQLite
# For Render, this will be auto-set from the database connection
DATABASE_URL=

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-app.onrender.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=FitZone <your-email@gmail.com>
SERVER_EMAIL=your-email@gmail.com

# Razorpay Configuration
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_SwU8wO2DuOpWoo
RAZORPAY_KEY_SECRET=hS7jKWDqXYQRbo3IoS6J3oMB

# Security Settings (for production)
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Site URL
SITE_URL=https://your-render-app.onrender.com
