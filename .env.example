# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-django-insecure

# Database
# For local development, leave this empty to use SQLite
# For production, set DATABASE_URL to your database connection string
DATABASE_URL=

# Allowed Hosts (update with your domain)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Email Configuration (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=FitZone <your-email@gmail.com>
SERVER_EMAIL=your-email@gmail.com

# If you use Render with Brevo SMTP, set credentials in the Render dashboard:
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<your-brevo-login>
# EMAIL_HOST_PASSWORD=<your-brevo-password>
# DEFAULT_FROM_EMAIL="FitZone <fitzone.alerts@gmail.com>"

# Razorpay Configuration (Test keys provided, use live keys for production)
RAZORPAY_KEY_ID=rzp_test_SwU8wO2DuOpWoo
RAZORPAY_KEY_SECRET=hS7jKWDqXYQRbo3IoS6J3oMB

# Security Settings (for production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Site URL (update with your production domain)
SITE_URL=https://yourdomain.com
